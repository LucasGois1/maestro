{
  "concurrency": 4,
  "sensors": [
    {
      "id": "go-test",
      "kind": "computational",
      "command": "go test ./..."
    },
    {
      "id": "go-vet",
      "kind": "computational",
      "command": "go vet ./..."
    },
    {
      "id": "code-review",
      "kind": "inferential",
      "agent": "code-reviewer",
      "onFail": "warn",
      "appliesTo": ["**/*.{py,ts,tsx,js,jsx,go,rs,java}"]
    }
  ]
}
