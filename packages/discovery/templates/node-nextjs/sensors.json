{
  "concurrency": 4,
  "sensors": [
    {
      "id": "eslint",
      "kind": "computational",
      "command": "pnpm exec eslint ."
    },
    {
      "id": "tsc",
      "kind": "computational",
      "command": "pnpm exec tsc --noEmit"
    },
    {
      "id": "code-review",
      "kind": "inferential",
      "agent": "code-reviewer",
      "onFail": "warn",
      "appliesTo": ["**/*.{py,ts,tsx,js,jsx,go,rs,java}"]
    }
  ]
}
